{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "openrouter/anthropic/claude-opus-4.8",
      "fallback_models": [
        { "model": "openrouter/anthropic/claude-sonnet-4.5" }
      ]
    },
